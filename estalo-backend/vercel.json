{
  "services": {
    "web": {
      "root": ".",
      "entrypoint": "app/main.py",
      "functions": {
        "app/main.py": {
          "maxDuration": 60
        }
      }
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "web"
      }
    }
  ]
}

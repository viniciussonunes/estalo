# ============================================================
#  Estalo Backend — variáveis de ambiente
#  Copie este arquivo para ".env" e preencha os valores reais.
#  NUNCA suba o ".env" para o GitHub (já está no .gitignore).
# ============================================================

# ── Banco de dados ───────────────────────────────────────────
# Dev local (SQLite — padrão, não precisa mudar):
DATABASE_URL=sqlite:///./estalo.db
# Produção — cole a URL interna que o Render/Railway fornece:
# DATABASE_URL=postgresql://usuario:senha@host:5432/estalo

# ── Segurança ────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-isso-em-producao
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Gemini ───────────────────────────────────────────────────
# Obtenha em https://aistudio.google.com/apikey
GEMINI_API_KEY=cole-sua-chave-aqui
GEMINI_MODEL=gemini-2.5-flash

# ── CORS ─────────────────────────────────────────────────────
# URL do frontend na Vercel (sem barra final). Vazio = só localhost.
FRONTEND_URL=https://seu-projeto.vercel.app

# ── Admin (/admin/*) ─────────────────────────────────────────
# Emails com acesso ao painel de gestão de cotas, separados por vírgula.
# Vazio = ninguém entra (não existe "admin de fábrica").
ADMIN_EMAILS=

# ── Observabilidade ──────────────────────────────────────────
# DSN do projeto Sentry (backend). Vazio = SDK desabilitado (nada é
# enviado) -- seguro deixar vazio em dev/CI.
SENTRY_DSN=

# Copie este arquivo para ".env" e ajuste os valores.

# Local (SQLite) — já é o padrão, não precisa mexer pra rodar.
DATABASE_URL=sqlite:///./estalo.db

# Produção (PostgreSQL) — descomente e ajuste quando for pro servidor.
# DATABASE_URL=postgresql://usuario:senha@host:5432/estalo

# Gere uma chave forte com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-isso-em-producao
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== IA (geração de cards) =====
# Pegue a chave em https://aistudio.google.com/apikey
# Cole o valor real aqui (sem aspas). NUNCA suba este arquivo pro GitHub.
GEMINI_API_KEY=cole-sua-chave-aqui
GEMINI_MODEL=gemini-flash-latest

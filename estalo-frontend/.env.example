# ============================================================
#  Estalo Frontend — variáveis de ambiente (Vite)
#  Copie para ".env.local" para dev, ou configure no painel
#  da Vercel em Settings > Environment Variables para produção.
#  Variáveis do Vite DEVEM começar com VITE_
# ============================================================

# URL do backend em produção (Render / Railway).
# Em dev local não precisa definir — usa http://localhost:8000 como padrão.
VITE_API_URL=https://seu-backend.onrender.com
